    "test:e2e": "playwright test",
    "test:integration": "vitest run tests/integration",
    "test:coverage": "vitest run --coverage",
    "test:ci": "playwright test --reporter=list",
    "test:ui": "playwright test --ui"
  },
  "prisma": {
